{
  "name": "@actalk/inkos-studio",
  "version": "1.2.0",
  "description": "InkOS Studio — Web workbench for novel writing",
  "type": "module",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos.git",
    "directory": "packages/studio"
  },
  "scripts": {
    "prepack": "npm run build && node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "dev": "vite --host --port 4567",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@actalk/inkos-core": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "@hono/node-server": "^1.13.0",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
